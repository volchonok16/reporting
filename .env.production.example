# Production: pallink.fun
#   cp .env.production.example .env
#   sudo bash scripts/production.sh

# Compose v2 (рекомендуется): docker compose
# COMPOSE_CMD=docker compose
# Только если нет плагина v2:
# COMPOSE_CMD=docker-compose

POSTGRES_USER=reporting
POSTGRES_PASSWORD=CHANGE_ME_STRONG
POSTGRES_DB=reporting
TASKHUB_ALEX_PASSWORD=CHANGE_ME
TASKHUB_IVAN_PASSWORD=CHANGE_ME

DATABASE_URL=postgresql+psycopg://alex:CHANGE_ME@postgres:5432/reporting

APP_PUBLIC_URL=https://pallink.fun
API_PUBLIC_URL=https://api.pallink.fun
CORS_ALLOW_ORIGINS=https://pallink.fun,https://www.pallink.fun
VITE_API_URL=https://api.pallink.fun

CERTBOT_EMAIL=admin@pallink.fun
CERTBOT_DOMAINS=pallink.fun,www.pallink.fun,api.pallink.fun

TFS_BASE_URL=https://tfs.t2.ru/tfs/Main
TFS_VERIFY_TLS=true
TFS_BATCH_SIZE=200
TFS_LINKED_BATCH_SIZE=200
TFS_REQUEST_DELAY_SECONDS=0.15
TFS_FETCH_ALL_FIELDS=false
TFS_FETCH_RELATIONS=false
TFS_EXCLUDE_CLOSED_OLDER_THAN_DAYS=365
TFS_SYNC_CLOSED_RETAIN_YEARS=3
DASHBOARD_CLOSED_VISIBLE_YEARS=1
TFS_PILOT_STATE_VALUES=Пилот,Pilot
TFS_FETCH_PILOT_HISTORY=true

BACKEND_WORKERS=2

# Вход по логину/паролю (выгрузка TFS — серверный PAT)
# Формат: login:password (по одному на строку)
APP_AUTH_USERS=sergey.balkovoy:CHANGE_ME
TFS_SYNC_PAT=CHANGE_ME

# Google Sheets — статус продукта B2B
# API-ключ AIzaSy… из Google Cloud. НЕ подставляйте сюда ссылку на таблицу.
GOOGLE_SHEETS_API_KEY=
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=/app/secrets/google-sheets-sa.json
# Если с сервера нет доступа к Google напрямую: http://proxy:3128
OUTBOUND_HTTP_PROXY=
B2B_PRODUCT_STATUS_SPREADSHEET_ID=1zTxzUqa1p6wFUjmk-8_2czfsJaSm3eTrNGazN0oFKqI
B2B_PRODUCT_STATUS_SHEET_URL=https://docs.google.com/spreadsheets/d/1zTxzUqa1p6wFUjmk-8_2czfsJaSm3eTrNGazN0oFKqI/export?format=csv&gid=0
B2B_PRODUCT_STATUS_SHEET_PUBLIC_URL=https://docs.google.com/spreadsheets/d/1zTxzUqa1p6wFUjmk-8_2czfsJaSm3eTrNGazN0oFKqI/edit
# gid:имя;gid2:имя2 — только числовые gid. Пусто = авто. НЕ URL презентации/таблицы.
B2B_PRODUCT_STATUS_SHEETS=
# Пусто — шаблон скачивается из B2B_PRODUCT_STATUS_PRESENTATION_REFERENCE_URL
B2B_PRODUCT_STATUS_PRESENTATION_TEMPLATE=
B2B_PRODUCT_STATUS_PRESENTATION_REFERENCE_URL=https://docs.google.com/presentation/d/1EDejas495X7XC3-pOW9QID_ooECrqNRYJBfrUpApCx4/edit

# Вкладка «Новости» — тот же GOOGLE_SHEETS_API_KEY и сервисный аккаунт
B2B_NEWS_SPREADSHEET_ID=1gaQvOWLzJ-KNKjLz2dVpD3wMTSBj-A04fhtC57ZxsSc
B2B_NEWS_SHEET_URL=https://docs.google.com/spreadsheets/d/1gaQvOWLzJ-KNKjLz2dVpD3wMTSBj-A04fhtC57ZxsSc/export?format=csv&gid=0
B2B_NEWS_SHEET_PUBLIC_URL=https://docs.google.com/spreadsheets/d/1gaQvOWLzJ-KNKjLz2dVpD3wMTSBj-A04fhtC57ZxsSc/edit
B2B_NEWS_SHEETS=
