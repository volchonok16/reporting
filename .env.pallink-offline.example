# Offline / HTTP: только pallink.fun (без SSL)
#
#   cp .env.pallink-offline.example .env
#   # на Mac: bash scripts/offline-bundle.sh
#   # на сервере:
#   sudo bash scripts/offline-deploy.sh /tmp/reporting-offline.tar --with-nginx --pallink
#
# DNS → IP сервера:
#   pallink.fun, www.pallink.fun, api.pallink.fun
#   minio.pallink.fun, minio-console.pallink.fun  (опционально)

POSTGRES_USER=reporting
POSTGRES_PASSWORD=CHANGE_ME_STRONG
POSTGRES_DB=reporting
TASKHUB_ALEX_PASSWORD=CHANGE_ME
TASKHUB_IVAN_PASSWORD=CHANGE_ME

DATABASE_URL=postgresql+psycopg://alex:CHANGE_ME@postgres:5432/reporting

APP_PUBLIC_URL=http://pallink.fun
API_PUBLIC_URL=http://pallink.fun
CORS_ALLOW_ORIGINS=http://pallink.fun,http://www.pallink.fun
# Frontend same-origin на pallink.fun — VITE_API_URL не обязателен
VITE_API_URL=

BACKEND_WORKERS=2

APP_AUTH_USERS=sergey.balkovoy:CHANGE_ME
TFS_SYNC_PAT=CHANGE_ME

TFS_BASE_URL=https://tfs.t2.ru/tfs/Main
TFS_VERIFY_TLS=true

MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=photos
# Пусто = фото через /api/org/photos/ (удобно без отдельного DNS minio)
MINIO_PUBLIC_URL=

ORG_UPLOADS_DIR=/app/uploads
