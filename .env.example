# Скопируйте в .env и при необходимости смените пароли:
#   cp .env.example .env

# Владелец БД (служебный, docker healthcheck)
# COMPOSE_CMD=docker-compose   # раскомментируйте, если нет плагина "docker compose"

POSTGRES_USER=reporting
POSTGRES_PASSWORD=reporting
POSTGRES_DB=reporting
POSTGRES_PORT=5432

# Пользователи с полными правами на БД reporting
TASKHUB_ALEX_PASSWORD=alex
TASKHUB_IVAN_PASSWORD=ivan

# Приложение (FastAPI + Vite)
DATABASE_URL=postgresql+psycopg://alex:alex@postgres:5432/reporting
TFS_BASE_URL=https://tfs.t2.ru/tfs/Main
TFS_VERIFY_TLS=true
TFS_BATCH_SIZE=200
TFS_LINKED_BATCH_SIZE=200
TFS_PILOT_STATE_VALUES=Пилот,Pilot
TFS_FETCH_PILOT_HISTORY=true
TFS_REQUEST_DELAY_SECONDS=0.15
TFS_TIMEOUT_SECONDS=45
TFS_API_VERSION=6.1
TFS_FETCH_ALL_FIELDS=false
TFS_FETCH_RELATIONS=false
TFS_WIQL_MAX_RESULTS=15000
TFS_CLOSED_STATE_VALUES=Closed
TFS_EXCLUDE_CLOSED_OLDER_THAN_DAYS=365
LAUNCHING_SOON_DAYS=60
APP_PUBLIC_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000
CORS_ALLOW_ORIGINS=

# Вход по логину/паролю приложения (синхронизация — через TFS_SYNC_PAT)
# Формат: login:password (по одному на строку)
APP_AUTH_USERS=sergey.balkovoy:CHANGE_ME
# Только вкладка Roadmap и синхронизация доски Digital Streams B2b
APP_AUTH_ROADMAP_USERS=roadmap.digital:CHANGE_ME
TFS_SYNC_PAT=

# Вкладка «Статус продукта B2B» (Google Sheets)
# API-ключ Google Cloud (Sheets API), формат AIzaSy… — НЕ ссылка на таблицу.
# Пусто — XLSX/CSV без частичного выделения в ячейках.
GOOGLE_SHEETS_API_KEY=
# Сервисный аккаунт Google для записи в таблицу: путь к JSON (Docker: /app/secrets/google-sheets-sa.json).
# Положите ключ в secrets/google-sheets-sa.json.
# Email из client_email добавьте в Google Sheets с правами «Редактор».
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=/app/secrets/google-sheets-sa.json
B2B_PRODUCT_STATUS_SPREADSHEET_ID=1zTxzUqa1p6wFUjmk-8_2czfsJaSm3eTrNGazN0oFKqI
B2B_PRODUCT_STATUS_SHEET_URL=https://docs.google.com/spreadsheets/d/1zTxzUqa1p6wFUjmk-8_2czfsJaSm3eTrNGazN0oFKqI/export?format=csv&gid=0
B2B_PRODUCT_STATUS_SHEET_PUBLIC_URL=https://docs.google.com/spreadsheets/d/1zTxzUqa1p6wFUjmk-8_2czfsJaSm3eTrNGazN0oFKqI/edit
# Список листов: 0:Лист1;123456:Лист2 (gid — число). Пусто = авто. НЕ URL.
B2B_PRODUCT_STATUS_SHEETS=
# Локальный PPTX-шаблон (опционально). Пусто — берётся эталон Google Slides ниже.
B2B_PRODUCT_STATUS_PRESENTATION_TEMPLATE=
# Эталон Google Slides: ссылка в UI и шаблон для «Скачать презентацию» (export/pptx).
B2B_PRODUCT_STATUS_PRESENTATION_REFERENCE_URL=https://docs.google.com/presentation/d/1EDejas495X7XC3-pOW9QID_ooECrqNRYJBfrUpApCx4/edit

# Вкладка «Новости» — тот же GOOGLE_SHEETS_API_KEY и сервисный аккаунт
B2B_NEWS_SPREADSHEET_ID=1gaQvOWLzJ-KNKjLz2dVpD3wMTSBj-A04fhtC57ZxsSc
B2B_NEWS_SHEET_URL=https://docs.google.com/spreadsheets/d/1gaQvOWLzJ-KNKjLz2dVpD3wMTSBj-A04fhtC57ZxsSc/export?format=csv&gid=0
B2B_NEWS_SHEET_PUBLIC_URL=https://docs.google.com/spreadsheets/d/1gaQvOWLzJ-KNKjLz2dVpD3wMTSBj-A04fhtC57ZxsSc/edit
# gid:имя;gid2:имя2 — только числовые gid. Пусто = авто (листы «Новости», «Запуски»).
B2B_NEWS_SHEETS=

# MinIO — фото сотрудников (bucket `photos` создаётся при docker compose up)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=photos
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
# Локальный fallback, если MinIO недоступен
ORG_UPLOADS_DIR=/app/uploads
# YouJail (вкладка «Доска»): worktree, вложения, команда исполнителя
YOUJAIL_WORKSPACE_DIR=/app/youjail-workspace
# Шаблон: echo "card {card_id}" (демо-режим, если пусто)
YOUJAIL_EXECUTOR_COMMAND=
YOUJAIL_MAX_ATTACHMENT_BYTES=10485760
