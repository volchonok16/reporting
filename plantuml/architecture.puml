@startuml architecture
title Архитектура reporting — ЗНИ, TFS, pallink.fun

skinparam componentStyle rectangle
skinparam defaultTextAlignment center

actor "Аналитик" as analyst

cloud "Internet" as inet

package "Production (VPS)" #LightGray {
  node "nginx + Let's Encrypt" as nginx {
    [pallink.fun\nHTTPS] as fe_ssl
    [api.pallink.fun\nHTTPS] as api_ssl
  }

  package "Docker Compose" #LightGreen {
    [Frontend\nVite + React\n:5173] as fe
    [Backend\nFastAPI\n:8000] as api
    database "PostgreSQL\n:5432" as pg
  }
}

package "Внешние системы" #LightBlue {
  [Azure DevOps\nTFS API] as tfs
}

package "Слой интеграции" #LightYellow {
  [TfsClient\nWIQL + Batch] as client
  [Sync Service] as sync
  [Auth PAT\nauth_session] as auth
}

analyst --> inet
inet --> nginx
fe_ssl --> fe : proxy
api_ssl --> api : proxy
fe --> api : REST\nX-Session-Id

api --> auth
api --> sync
api --> pg
auth --> pg
sync --> client
sync --> pg
client --> tfs : PAT

note right of pg
  **ЗНИ:** task_type = change_request
  **Ошибка:** task_type = error
  parent_task_id → ЗНИ
  auth_session — PAT (сервер)
end note

note bottom of sync
  Оптимизация:
  • поля без $expand All
  • ошибки через WIQL WorkItemLinks
  • Closed > 365 дней — пропуск
  Доски: Digital Streams B2b, BE-T2 Team
end note

note bottom of nginx
  Запуск: sudo bash scripts/production.sh
  certbot → /etc/letsencrypt/live/pallink.fun
end note

@enduml
