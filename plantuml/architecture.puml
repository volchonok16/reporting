@startuml architecture
title Архитектура: reporting — ЗНИ и ошибки TFS

skinparam componentStyle rectangle
skinparam defaultTextAlignment center

actor "Аналитик" as analyst

package "Внешние системы" #LightBlue {
  [Azure DevOps\nTFS API] as tfs
}

package "Веб-приложение" #LightGreen {
  [Frontend\nVite + React] as fe
  [Backend\nFastAPI] as api
}

package "Слой интеграции TFS" #LightYellow {
  [TfsClient\nWIQL + workItemsBatch] as client
  [Sync Service\nЗНИ + Ошибки] as sync
  [Auth Sessions\nPAT] as auth
}

database "PostgreSQL\nreporting" as pg {
  frame "Справочники" {
    [source_system]
    [team]
    [project]
  }
  frame "Данные" {
    [task\nchange_request / error]
    [sync_run]
    [auth_session]
  }
  frame "Отчёты" {
    [v_task_backlog_duration]
    [v_team_open_tasks]
  }
}

analyst --> fe : фильтры, экспорт
fe --> api : REST + X-Session-Id
api --> auth
api --> sync
sync --> client
client --> tfs : PAT
sync --> pg
auth --> pg
api --> pg : dashboard, CSV

note right of task
  **ЗНИ:** task_type = change_request
  **Ошибка:** task_type = error
  parent_task_id → ЗНИ
  start_date: StartDate или CreatedDate
  release_date: TargetDate
end note

note bottom of fe
  Доски:
  Digital Streams B2b (Tele2)
  BE-T2 Team (BE-T2)
end note

@enduml
