@startuml database-er
' ER для Confluence / docs — без тестовых данных

skinparam shadowing false
skinparam linetype ortho
skinparam roundCorner 6
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #42526E
skinparam arrowColor #42526E
skinparam packageBorderColor #DFE1E6
skinparam packageFontColor #172B4D

title База данных reporting (PostgreSQL)

package "Справочники" #E8F4FC {
  class source_system <<table>> {
    +id : smallserial PK
    code : varchar UK
    name : varchar
    base_url : text
    is_active : boolean
  }

  class canonical_status <<table>> {
    +id : serial PK
    code : varchar UK
    name : varchar
    category : varchar
    sort_order : int
    is_terminal : boolean
  }

  class source_status_mapping <<table>> {
    +id : serial PK
    source_system_id : FK
    source_status_name : varchar
    canonical_status_id : FK
    project_external_key : varchar
  }

  class field_mapping <<table>> {
    +id : serial PK
    source_system_id : FK
    source_entity : varchar
    source_field_path : varchar
    canonical_field : varchar
    transform_rule : text
  }

  class team <<table>> {
    +id : bigserial PK
    code : varchar UK
    name : varchar
  }

  class person <<table>> {
    +id : bigserial PK
    email : varchar UK
    display_name : varchar
  }

  class person_external <<table>> {
    +id : bigserial PK
    person_id : FK
    source_system_id : FK
    external_user_id : varchar
  }
}

package "Проекты и релизы" #E8FCF0 {
  class project <<table>> {
    +id : bigserial PK
    source_system_id : FK
    external_key : varchar
    name : varchar
    team_id : FK
  }

  class release <<table>> {
    +id : bigserial PK
    project_id : FK
    name : varchar
    planned_release_date : date
    actual_release_date : date
    status : varchar
  }
}

package "Задачи" #FFF8E8 {
  class task <<table>> {
    +id : bigserial PK
    uuid : uuid UK
    source_system_id : FK
    external_id : varchar
    project_id : FK
    team_id : FK
    parent_task_id : FK
    --
    title : varchar
    task_type : varchar
    source_status : varchar
    source_team : varchar
    created_at : timestamptz
    start_date : date
    release_date : date
    closed_at : timestamptz
    extra_json : jsonb
  }

  class task_release <<table>> {
    task_id : FK PK
    release_id : FK PK
  }

  class task_comment <<table>> {
    +id : bigserial PK
    task_id : FK
    source_system_id : FK
    body : text
    created_at : timestamptz
  }

  class task_assignee_history <<table>> {
    +id : bigserial PK
    task_id : FK
    assignee_id : FK
    assigned_at : timestamptz
    unassigned_at : timestamptz
  }
}

package "Статусы и время" #FCE8F4 {
  class task_status_history <<table>> {
    +id : bigserial PK
    task_id : FK
    from_canonical_status_id : FK
    to_canonical_status_id : FK
    changed_at : timestamptz
    changed_by_id : FK
  }

  class task_status_duration <<table>> {
    +id : bigserial PK
    task_id : FK
    canonical_status_id : FK
    entered_at : timestamptz
    left_at : timestamptz
    duration_seconds : bigint
    is_current : boolean
  }

  class task_status_duration_agg <<table>> {
    task_id : FK PK
    canonical_status_id : FK PK
    total_seconds : bigint
  }
}

package "Приложение и синхронизация" #F0E8FC {
  class auth_session <<table>> {
    +id : varchar PK
    payload : jsonb
    created_at : timestamptz
  }

  class sync_run <<table>> {
    +id : bigserial PK
    source_system_id : FK
    started_at : timestamptz
    status : varchar
    records_fetched : int
    records_upserted : int
    parameters_json : jsonb
  }

  class sync_run_log <<table>> {
    +id : bigserial PK
    sync_run_id : FK
    level : varchar
    message : text
  }

  class team_workload_snapshot <<table>> {
    +id : bigserial PK
    team_id : FK
    snapshot_date : date
    backlog_count : int
    active_count : int
  }
}

package "Staffing / Org" #E8FCE8 {
  class org_user <<table>> {
    +id : bigserial PK
    email : varchar UK
    role : smallint
  }

  class employee <<table>> {
    +id : bigserial PK
    public_id : uuid UK
    full_name : varchar
    user_id : FK
    manager_id : FK
  }

  class department <<table>> {
    +id : bigserial PK
    name : varchar
    head_employee_id : FK
  }

  class department_member <<table>> {
    +id : bigserial PK
    department_id : FK
    employee_id : FK
  }

  class employee_time_off_day <<table>> {
    employee_id : FK
    day : date
    kind : varchar
  }

  class workspace_place <<table>> {
    +id : bigserial PK
    name : varchar
    sort_order : int
  }

  class workspace_booking <<table>> {
    place_id : FK
    employee_id : FK
    day : date
  }

  class employee_office_day <<table>> {
    employee_id : FK
    day : date
  }

  class org_chart_layout <<table>> {
    scope : varchar
    department_id : FK
    layout_json : jsonb
  }
}

package "YouJail (Доска)" #FFF0E0 {
  class youjail_board <<table>> {
    +id : bigserial PK
    slug : varchar
    owner_employee_id : FK
  }

  class youjail_column <<table>> {
    +id : bigserial PK
    board_id : FK
    name : varchar
  }

  class youjail_card <<table>> {
    +id : bigserial PK
    board_id : FK
    column_id : FK
    title : varchar
  }

  class youjail_card_zni <<table>> {
    card_id : FK
    task_id : FK
  }
}

package "Статус продукта B2B" #E0F0FF {
  class b2b_product_status_office <<table>> {
    +id : bigserial PK
    code : varchar
    name : varchar
  }

  class b2b_product_status_row <<table>> {
    +id : bigserial PK
    office_id : FK
    cells : jsonb
  }

  class b2b_news_section <<table>> {
    +id : bigserial PK
    code : varchar
  }

  class b2b_news_row <<table>> {
    +id : bigserial PK
    section_id : FK
    cells : jsonb
  }

  class revenue_activity_section <<table>> {
    +id : bigserial PK
    gid : varchar
  }

  class revenue_activity_row <<table>> {
    +id : bigserial PK
    section_id : FK
    cells : jsonb
  }
}

package "Представления (FineBI)" #EEEEEE {
  class v_task_backlog_duration <<view>>
  class v_task_status_time <<view>>
  class v_team_open_tasks <<view>>
  class v_tasks_by_release <<view>>
}

source_system "1" -- "0..*" project
source_system "1" -- "0..*" task
source_system "1" -- "0..*" field_mapping
source_system "1" -- "0..*" source_status_mapping
source_system "1" -- "0..*" sync_run

team "1" -- "0..*" project
team "1" -- "0..*" task
team "1" -- "0..*" team_workload_snapshot

project "1" -- "0..*" task
project "1" -- "0..*" release

canonical_status "1" -- "0..*" task
canonical_status "1" -- "0..*" task_status_duration
canonical_status "1" -- "0..*" source_status_mapping

person "1" -- "0..*" person_external
person "1" -- "0..*" task : assignee
person "1" -- "0..*" task_comment

task "0..1" -- "0..*" task : parent
task "1" -- "0..*" task_comment
task "1" -- "0..*" task_status_history
task "1" -- "0..*" task_status_duration
task "1" -- "0..*" task_assignee_history
task "0..*" -- "0..*" release : task_release

task_status_duration ..> v_task_backlog_duration : feeds
task_status_duration ..> v_task_status_time : feeds
task ..> v_tasks_by_release : feeds
team ..> v_team_open_tasks : feeds

org_user "0..1" -- "0..1" employee
employee "0..1" -- "0..*" employee : manager
department "1" -- "0..*" department_member
employee "1" -- "0..*" department_member
employee "1" -- "0..*" employee_time_off_day
employee "1" -- "0..*" workspace_booking
employee "1" -- "0..*" employee_office_day
workspace_place "1" -- "0..*" workspace_booking
department "0..1" -- "0..*" org_chart_layout

youjail_board "1" -- "0..*" youjail_column
youjail_board "1" -- "0..*" youjail_card
youjail_column "1" -- "0..*" youjail_card
youjail_card "1" -- "0..*" youjail_card_zni
task "1" -- "0..*" youjail_card_zni

b2b_product_status_office "1" -- "0..*" b2b_product_status_row
b2b_news_section "1" -- "0..*" b2b_news_row
revenue_activity_section "1" -- "0..*" revenue_activity_row

note right of source_system
  **Коды источников:**
  jira · tfs · trello · other
end note

note right of task
  **ЗНИ:** task_type = change_request
  **Ошибка:** task_type = error
  parent_task_id → ЗНИ
  Планы: extra_json.roadmap_*
end note

note bottom of auth_session
  PAT TFS или app login;
  клиент — только sessionId
end note

note bottom of workspace_booking
  Staffing: бронь места на день
end note

note bottom of b2b_product_status_row
  PPTX: /api/product-status/b2b/presentation
end note

note bottom of task_status_duration
  **Время в бэклоге:**
  canonical_status.category = 'backlog'
end note

@enduml
