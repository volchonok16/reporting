@startuml use-case
left to right direction
skinparam packageStyle rectangle

title Use Case — reporting (ЗНИ + единая БД)

actor "Аналитик" as analyst
actor "Администратор" as admin
actor "FineBI" as bi

rectangle "Система reporting" {

  package "Веб-приложение (pallink.fun)" {
    usecase "Вход по PAT TFS" as UC_AUTH
    usecase "Дашборд ЗНИ\n(фильтры, метрики)" as UC_DASH
    usecase "Синхронизация\nиз TFS" as UC_SYNC
    usecase "Экспорт CSV\n(ЗНИ + ошибки)" as UC_EXPORT
    usecase "Все доски /\nодна доска" as UC_BOARD
  }

  package "Отчётность BI" {
    usecase "Время в статусах" as UC2
    usecase "Время в бэклоге" as UC3
    usecase "Загрузка команды" as UC4
    usecase "Отгрузка в релиз" as UC5
  }

  package "Администрирование" {
    usecase "Маппинг полей\nи статусов" as UC6
  }

  package "Интеграция TFS" {
    usecase "WIQL → Batch ЗНИ" as UC9A
    usecase "WIQL связи\nЗНИ → Ошибка" as UC9B
    usecase "Upsert task" as UC9C
    usecase "Аудит sync_run" as UC16
  }
}

analyst --> UC_AUTH
analyst --> UC_DASH
analyst --> UC_SYNC
analyst --> UC_EXPORT
analyst --> UC_BOARD

bi --> UC2
bi --> UC3
bi --> UC4
bi --> UC5

admin --> UC6

UC_SYNC ..> UC9A : <<include>>
UC_SYNC ..> UC9B : <<include>>
UC_SYNC ..> UC9C : <<include>>
UC_SYNC ..> UC16 : <<include>>
UC_DASH ..> UC_AUTH : <<include>>

@enduml
